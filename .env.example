RENDER_BACKEND_URL=

# Serper API Key (Kunci akses modul OSINT Pelacakan Web dan Google Places)
# Dapat didaftarkan secara gratis di serper.dev
SERPER_API_KEY=SERPER_API_KEY_HERE
