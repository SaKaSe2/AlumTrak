# Supabase Configurations (Koneksi Database OSINT & Realtime Data)
# Isi dengan URL dan Key dari dashboard Supabase proyek
NEXT_PUBLIC_SUPABASE_URL=NEXT_PUBLIC_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=NEXT_PUBLIC_SUPABASE_ANON_KEY_HERE

# Render Backend URL (Untuk memanggil modul Puppeteer Stealth pada server terpisah)
