<meta charset="utf-8">
<style>
  body { font-family: "Times New Roman", Times, serif; font-size: 12pt; line-height: 1.5; padding: 2cm; }
  h1 { font-size: 16pt; text-align: center; text-transform: uppercase; font-weight: bold; }
  h2 { font-size: 14pt; text-align: center; text-transform: uppercase; font-weight: bold; margin-bottom: 30px; }
  h3 { font-size: 12pt; font-weight: bold; margin-top: 20px; text-decoration: underline; background-color: #e6e6e6; padding: 5px; }
